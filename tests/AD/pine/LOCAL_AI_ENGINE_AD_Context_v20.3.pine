//@version=5
indicator("LOCAL_AI_ENGINE A/D Context v20.3", overlay=false, max_labels_count=500, max_lines_count=500)

// ============================================================================
// v20.3 - патч: стабильный CMF (cum-diff), нормализация потока, divergence по flowNorm
// ============================================================================

// ----------------------------- Inputs --------------------------------------
groupFlow = "Flow"
flowMode  = input.string("Williams AD", "Flow Mode", options=["Chaikin AD", "Williams AD"], group=groupFlow)
cmfLen    = input.int(20, "CMF Length", minval=1, group=groupFlow)
emaLen    = input.int(21, "A/D Smoothing EMA", minval=1, group=groupFlow)
atrLen    = input.int(14, "ATR Length", minval=1, group=groupFlow)

groupTF = "TF Profile"
useAutoTfProfile = input.bool(true, "Auto TF Profile", group=groupTF)
manualProfile    = input.string("1h", "Manual Profile", options=["15m", "1h", "4h", "1d"], group=groupTF)

groupDiv = "Divergence"
pivotLeftBase   = input.int(12, "Pivot Left", minval=1, group=groupDiv)
pivotRightBase  = input.int(12, "Pivot Right", minval=1, group=groupDiv)
minPriceMovePct = input.float(0.15, "Min Price Move %", minval=0.0, step=0.05, group=groupDiv)
minAdMovePct    = input.float(0.35, "Min A/D Move (fraction)", minval=0.0, step=0.01, group=groupDiv)
minSwingAtr     = input.float(0.8, "Min Swing ATR", minval=0.0, step=0.1, group=groupDiv)
cooldownBars    = input.int(20, "Divergence Cooldown Bars", minval=1, group=groupDiv)

groupRegime = "Regime"
regimeLookback    = input.int(8, "Regime Lookback", minval=2, group=groupRegime)
regimeMinSlopePct = input.float(0.20, "Min EMA Slope %", minval=0.0, step=0.01, group=groupRegime)
regimeMinRangePct = input.float(0.25, "Min EMA Range %", minval=0.0, step=0.01, group=groupRegime)
regimeConfirmBars = input.int(4, "Regime Confirm Bars", minval=1, group=groupRegime)

groupConfirm = "Confirmation"
breakoutLen = input.int(5, "Breakout Lookback (base)", minval=2, group=groupConfirm)
cmfStrong   = input.float(0.05, "CMF Strong Threshold (base)", minval=0.0, step=0.01, group=groupConfirm)
cmfWeak     = input.float(0.02, "CMF Weak Threshold (base)", minval=0.0, step=0.01, group=groupConfirm)

groupWeights = "Bias Weights"
wFlow   = input.float(1.0, "Weight: Flow Slope",  minval=0.0, step=0.1, group=groupWeights)
wCmf    = input.float(1.5, "Weight: CMF Score",   minval=0.0, step=0.1, group=groupWeights)
wRegime = input.float(1.0, "Weight: Regime",      minval=0.0, step=0.1, group=groupWeights)
biasThresh = input.float(2.0, "Bias Score Threshold", minval=0.5, step=0.1, group=groupWeights)

groupContext = "Context"
showBias       = input.bool(true, "Show Bias Background", group=groupContext)
showCMF        = input.bool(true, "Show CMF", group=groupContext)
showDivergence = input.bool(true, "Show Divergence Labels", group=groupContext)
showTable      = input.bool(true, "Show Context Table", group=groupContext)
showNorm       = input.bool(true, "Show Normalized Flow (flow_z)", group=groupContext)

// -------------------------- TF profile selection ---------------------------
profile =
     useAutoTfProfile ?
         timeframe.isminutes and timeframe.multiplier <= 15 ? "15m" :
         timeframe.isminutes and timeframe.multiplier <= 60 ? "1h" :
         timeframe.isminutes and timeframe.multiplier <= 240 ? "4h" : "1d"
     : manualProfile

pivotLeft =
     profile == "15m" ? math.max(pivotLeftBase, 10) :
     profile == "1h"  ? math.max(pivotLeftBase, 12) :
     profile == "4h"  ? math.max(pivotLeftBase, 14) : math.max(pivotLeftBase, 16)

pivotRight =
     profile == "15m" ? math.max(pivotRightBase, 10) :
     profile == "1h"  ? math.max(pivotRightBase, 12) :
     profile == "4h"  ? math.max(pivotRightBase, 14) : math.max(pivotRightBase, 16)

profilePriceMovePct =
     profile == "15m" ? minPriceMovePct * 1.4 :
     profile == "1h"  ? minPriceMovePct * 1.2 :
     profile == "4h"  ? minPriceMovePct * 1.0 : minPriceMovePct * 0.8

profileAdMovePct =
     profile == "15m" ? minAdMovePct * 1.4 :
     profile == "1h"  ? minAdMovePct * 1.2 :
     profile == "4h"  ? minAdMovePct * 1.0 : minAdMovePct * 0.8

profileAtrMult =
     profile == "15m" ? minSwingAtr * 1.0 :
     profile == "1h"  ? minSwingAtr * 1.1 :
     profile == "4h"  ? minSwingAtr * 1.2 : minSwingAtr * 1.3

profileCooldown =
     profile == "15m" ? cooldownBars :
     profile == "1h"  ? cooldownBars + 5 :
     profile == "4h"  ? cooldownBars + 10 : cooldownBars + 15

cmfStrongTf =
     profile == "15m" ? 0.04 :
     profile == "1h"  ? 0.05 :
     profile == "4h"  ? 0.06 : 0.07

cmfWeakTf =
     profile == "15m" ? 0.015 :
     profile == "1h"  ? 0.02 :
     profile == "4h"  ? 0.025 : 0.03

brLen =
     profile == "15m" ? 4 :
     profile == "1h"  ? 5 :
     profile == "4h"  ? 6 : 8

// ----------------------------- Flow Core -----------------------------------
small = 1e-9
barRange = math.max(high - low, syminfo.mintick)
mfm      = ((close - low) - (high - close)) / barRange
mfv      = mfm * volume

// rawFlow (Chaikin / volume-weighted)
rawFlow = ta.cum(mfv)
smoothedFlow = ta.ema(rawFlow, emaLen)
flowSlope    = smoothedFlow - smoothedFlow[1]

// ------------------------------- CMF (fallback safe) ----------------------
cumMFV = ta.cum(mfv)
cumVol = ta.cum(volume)
sumMFV = na(cumMFV[cmfLen]) ? cumMFV : cumMFV - cumMFV[cmfLen]
sumVol = na(cumVol[cmfLen]) ? cumVol : cumVol - cumVol[cmfLen]
cmfVal = (not na(sumMFV) and not na(sumVol) and sumVol != 0) ? sumMFV / sumVol : 0.0

atrVal = ta.atr(atrLen)

// ----------------------------- Normalizer / z-score -------------------------
flowScale = ta.ema(math.abs(rawFlow), math.max(5, regimeLookback))
flowNorm = smoothedFlow / math.max(flowScale, small)

float flowMean = ta.sma(smoothedFlow, cmfLen)
float flowStd  = ta.stdev(smoothedFlow, cmfLen)
float flow_z   = flowStd > syminfo.mintick ? (smoothedFlow - flowMean) / flowStd : 0.0

float flowHi  = ta.highest(smoothedFlow, cmfLen)
float flowLo  = ta.lowest(smoothedFlow, cmfLen)
float flow_pct = (flowHi - flowLo) > syminfo.mintick ? (smoothedFlow - flowLo) / (flowHi - flowLo) : 0.5

// ------------------------------ Regime ------------------------------------
float lagFlow   = smoothedFlow[regimeLookback]
float denomStab = math.max(math.abs(lagFlow), ta.sma(math.abs(smoothedFlow), regimeLookback), syminfo.mintick)
emaSlopePct = (smoothedFlow - lagFlow) / denomStab * 100
emaRangePct = math.abs(flowHi - flowLo) / math.max(math.abs(smoothedFlow), syminfo.mintick) * 100

var int bullCount = 0
var int bearCount = 0
bullCount := smoothedFlow > smoothedFlow[1] ? bullCount + 1 : 0
bearCount := smoothedFlow < smoothedFlow[1] ? bearCount + 1 : 0

bullRegime = bullCount >= regimeConfirmBars and emaSlopePct > regimeMinSlopePct and emaRangePct > regimeMinRangePct and smoothedFlow > lagFlow
bearRegime = bearCount >= regimeConfirmBars and emaSlopePct < -regimeMinSlopePct and emaRangePct > regimeMinRangePct and smoothedFlow < lagFlow

adRegime =
     bullRegime ? "bull" :
     bearRegime ? "bear" :
     math.abs(emaSlopePct) < regimeMinSlopePct ? "flat" : "transition"

if adRegime == "flat"
    adRegime := flowSlope < 0 and cmfVal < -cmfWeakTf ? "bear" : flowSlope > 0 and cmfVal > cmfWeakTf ? "bull" : "flat"

// -------------------------------- Bias -------------------------------------
flowScore =
     flowSlope > 0 ? 1.0 :
     flowSlope < 0 ? -1.0 : 0.0

cmfScore =
     cmfVal > cmfStrongTf  ?  1.5 :
     cmfVal > cmfWeakTf    ?  0.5 :
     cmfVal < -cmfStrongTf ? -1.5 :
     cmfVal < -cmfWeakTf   ? -0.5 : 0.0

regimeScore = bullRegime ? 1.0 : bearRegime ? -1.0 : 0.0

biasScore = flowScore * wFlow + cmfScore * wCmf + regimeScore * wRegime

adBias =
     biasScore >=  biasThresh ? "bullish" :
     biasScore <= -biasThresh ? "bearish" : "neutral"

// --------------------------- Confirmation ----------------------------------
bullBreak = close >= ta.highest(high, brLen)
bearBreak = close <= ta.lowest(low, brLen)

bullConfirmStrong = adBias == "bullish" and cmfVal > cmfStrongTf and flowSlope > 0 and bullBreak
bearConfirmStrong = adBias == "bearish" and cmfVal < -cmfStrongTf and flowSlope < 0 and bearBreak

bullConfirmWeak = adBias == "bullish" and cmfVal > cmfWeakTf and flowSlope > 0
bearConfirmWeak = adBias == "bearish" and cmfVal < -cmfWeakTf and flowSlope < 0

adConfirmation =
     bullConfirmStrong ? "strong_bullish" :
     bearConfirmStrong ? "strong_bearish" :
     bullConfirmWeak or bearConfirmWeak ? "weak" : "none"

// --------------------------- Divergence (patched, safe) --------------------
// use flowNorm / flow_z and absolute floor to avoid tiny-base percent explosions

pl = ta.pivotlow(low, pivotLeft, pivotRight)
ph = ta.pivothigh(high, pivotLeft, pivotRight)

// per-bar boolean (no persistent var true carry-over)
bullDiv = false
bearDiv = false

var float prevPriceLow = na
var float prevFlowLow  = na
var int   prevBullBar  = na

var float prevPriceHigh = na
var float prevFlowHigh  = na
var int   prevBearBar   = na

// minimal absolute change floor (fraction of local flowScale)
// ---- Fix: compute minFlowAbsChange in units of flowNorm (use stdev of flowNorm) ----
minFlowAbsFrac = 0.03  // tune per-TF: 15m -> 0.05, 1h -> 0.04, 4h -> 0.03, 1d -> 0.02

// compute stdev of flowNorm over cmfLen (fallback-safe)
flowNormStd = ta.stdev(flowNorm, cmfLen)
minFlowAbsChange = math.max(flowNormStd * minFlowAbsFrac, 1e-9)

// Then use flowAbsChange (already in flowNorm units) for comparison:
// flowFracChange = math.abs(currFlowLow - prevFlowLow) / math.max(math.abs(prevFlowLow), small)
// flowAbsChange = math.abs(currFlowLow - prevFlowLow)
// flowMoveOk = (flowFracChange >= profileAdMovePct) and (flowAbsChange >= minFlowAbsChange)

if not na(pl)
    currBar = bar_index - pivotRight
    currPriceLow = low[pivotRight]
    currFlowLow  = flowNorm[pivotRight]  // normalized flow at pivot

    if not na(prevPriceLow) and not na(prevFlowLow)
        // price relative change (fraction)
        priceMoveOk = math.abs(currPriceLow - prevPriceLow) / math.max(prevPriceLow, small) >= profilePriceMovePct

        // flow relative change (fraction) + absolute floor
        flowFracChange = math.abs(currFlowLow - prevFlowLow) / math.max(math.abs(prevFlowLow), small)
        localFlowScale = math.max(math.abs(flowScale[pivotRight]), small)
        minFlowAbsChangeLocal = math.max(localFlowScale * minFlowAbsFrac, 1e-9)
        flowAbsChange = math.abs(currFlowLow - prevFlowLow)
        flowMoveOk = (flowFracChange >= profileAdMovePct) and (flowAbsChange >= minFlowAbsChange)

        atrOk = math.abs(currPriceLow - prevPriceLow) >= atrVal[pivotRight] * profileAtrMult

        rawBull = (currPriceLow < prevPriceLow) and (currFlowLow > prevFlowLow) and priceMoveOk and flowMoveOk and atrOk
        cooldownOk = na(prevBullBar) or (currBar - prevBullBar >= profileCooldown)

        if rawBull and cooldownOk
            bullDiv := true
            prevBullBar := currBar

    prevPriceLow := currPriceLow
    prevFlowLow  := currFlowLow

if not na(ph)
    currBar = bar_index - pivotRight
    currPriceHigh = high[pivotRight]
    currFlowHigh  = flowNorm[pivotRight]

    if not na(prevPriceHigh) and not na(prevFlowHigh)
        priceMoveOk = math.abs(currPriceHigh - prevPriceHigh) / math.max(prevPriceHigh, small) >= profilePriceMovePct

        flowFracChange = math.abs(currFlowHigh - prevFlowHigh) / math.max(math.abs(prevFlowHigh), small)
        localFlowScale = math.max(math.abs(flowScale[pivotRight]), small)
        minFlowAbsChangeLocal = math.max(localFlowScale * minFlowAbsFrac, 1e-9)
        flowAbsChange = math.abs(currFlowHigh - prevFlowHigh)
        flowMoveOk = (flowFracChange >= profileAdMovePct) and (flowAbsChange >= minFlowAbsChange)

        atrOk = math.abs(currPriceHigh - prevPriceHigh) >= atrVal[pivotRight] * profileAtrMult

        rawBear = (currPriceHigh > prevPriceHigh) and (currFlowHigh < prevFlowHigh) and priceMoveOk and flowMoveOk and atrOk
        cooldownOk = na(prevBearBar) or (currBar - prevBearBar >= profileCooldown)

        if rawBear and cooldownOk
            bearDiv := true
            prevBearBar := currBar

    prevPriceHigh := currPriceHigh
    prevFlowHigh  := currFlowHigh

adDivergence =
     bullDiv ? "bullish" :
     bearDiv ? "bearish" : "none"

// ----------------------------- Quality -------------------------------------
qualityScore = 0
qualityScore += adBias == "bullish" or adBias == "bearish" ? 1 : 0
qualityScore += adConfirmation == "strong_bullish" or adConfirmation == "strong_bearish" ? 2 : adConfirmation == "weak" ? 1 : 0
qualityScore += adDivergence != "none" ? 1 : 0
qualityScore += adRegime == "bull" or adRegime == "bear" ? 1 : 0

adQuality =
     qualityScore >= 5 ? "high" :
     qualityScore >= 3 ? "medium" : "low"

// ----------------------------- Comment -------------------------------------
countertrend = (adBias == "bearish" and flowSlope > 0) or (adBias == "bullish" and flowSlope < 0)

adComment =
     countertrend ? "countertrend flow vs bias" :
     adDivergence == "bullish" ? "bullish divergence against down pressure" :
     adDivergence == "bearish" ? "bearish divergence against up pressure" :
     adConfirmation == "strong_bullish" ? "bullish volume confirmation" :
     adConfirmation == "strong_bearish" ? "bearish volume confirmation" :
     adBias == "bullish" ? "bullish volume pressure" :
     adBias == "bearish" ? "bearish volume pressure" : "neutral volume context"

// ----------------------------- Plotting -----------------------------------
hline(0, "Zero", color=color.new(color.gray, 80))

plot(rawFlow,      "Raw Flow",      color=color.new(color.teal,   0), linewidth=1)
plot(smoothedFlow, "Smoothed Flow", color=color.new(color.orange, 0), linewidth=2)
plot(showCMF  ? cmfVal  : na, "CMF",     color=color.new(color.blue,   0), linewidth=2)

plot(showNorm ? flow_z   : na, "flow_z",   color=color.new(color.purple, 0), linewidth=1)
plot(showNorm ? flow_pct : na, "flow_pct", color=color.new(color.yellow, 0), linewidth=1)

bgcolor(showBias ?
     (adBias == "bullish" ? color.new(color.green, 90) :
      adBias == "bearish" ? color.new(color.red,   90) :
      color.new(color.gray, 95))
     : na)

// Divergence labels — привязаны к smoothedFlow[pivotRight]
if showDivergence and bullDiv
    label.new(bar_index - pivotRight, smoothedFlow[pivotRight],
         "", style=label.style_triangleup,
         color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if showDivergence and bearDiv
    label.new(bar_index - pivotRight, smoothedFlow[pivotRight],
         "", style=label.style_triangledown,
         color=color.new(color.red, 0), textcolor=color.white, size=size.small)

// -------------------------- Context Table (outputs) ------------------------
var table t = table.new(position.top_right, 1, 14, border_width=1)

if barstate.islast and showTable
    table.cell(t, 0,  0, "profile: "          + profile,                                  text_color=color.white, bgcolor=color.new(color.black,  70))
    table.cell(t, 0,  1, "flow_mode: "         + flowMode,                                 text_color=color.white, bgcolor=color.new(color.black,  70))
    table.cell(t, 0,  2, "ad_bias: "           + adBias,                                   text_color=color.white, bgcolor=adBias == "bullish" ? color.new(color.green, 45) : adBias == "bearish" ? color.new(color.red, 45) : color.new(color.gray, 70))
    table.cell(t, 0,  3, "ad_confirmation: "   + adConfirmation,                           text_color=color.white, bgcolor=adConfirmation == "strong_bullish" ? color.new(color.green, 60) : adConfirmation == "strong_bearish" ? color.new(color.red, 60) : color.new(color.gray, 75))
    table.cell(t, 0,  4, "ad_divergence: "     + adDivergence,                             text_color=color.white, bgcolor=adDivergence == "bullish" ? color.new(color.green, 50) : adDivergence == "bearish" ? color.new(color.red, 50) : color.new(color.black, 70))
    table.cell(t, 0,  5, "ad_regime: "         + adRegime,                                 text_color=color.white, bgcolor=adRegime == "bull" ? color.new(color.green, 40) : adRegime == "bear" ? color.new(color.red, 40) : color.new(color.gray, 60))
    table.cell(t, 0,  6, "ad_quality: "        + adQuality,                                text_color=color.white, bgcolor=adQuality == "high" ? color.new(color.green, 35) : adQuality == "medium" ? color.new(color.orange, 45) : color.new(color.gray, 70))
    table.cell(t, 0,  7, "cmf: "              + str.tostring(cmfVal,       format.mintick), text_color=color.white, bgcolor=color.new(color.blue,   70))
    table.cell(t, 0,  8, "flow_slope: "       + str.tostring(flowSlope,    format.mintick), text_color=color.white, bgcolor=color.new(color.purple, 75))
    table.cell(t, 0,  9, "raw_flow: "         + str.tostring(rawFlow,      format.mintick), text_color=color.white, bgcolor=color.new(color.black,  70))
    table.cell(t, 0, 10, "smoothed_flow: "    + str.tostring(smoothedFlow, format.mintick), text_color=color.white, bgcolor=color.new(color.black,  70))
    table.cell(t, 0, 11, "flow_z: "           + str.tostring(flow_z,       "#.##"),         text_color=color.white, bgcolor=color.new(color.purple, 60))
    table.cell(t, 0, 12, "flow_pct: "         + str.tostring(flow_pct * 100, "#.#") + "%",  text_color=color.white, bgcolor=color.new(color.purple, 60))
    table.cell(t, 0, 13, "comment: "          + adComment,                                  text_color=color.white, bgcolor=color.new(color.black,  75))