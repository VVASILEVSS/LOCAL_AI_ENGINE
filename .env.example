# === Telegram бот ===
TOKEN=your_telegram_bot_token_here
MY_CHAT_ID=your_telegram_chat_id_here

# === LLM настройки ===
# Облачная модель (Alibaba GLM, OpenRouter и др. — любой OpenAI-compatible).
# Пустой ключ = local mode (LM Studio / Ollama на localhost без авторизации).
LLM_API_KEY=your_api_key_here

# base_url для LLM (БЕЗ /v1 — service сам добавляет /v1/chat/completions).
# Cloud (Alibaba GLM — работает из KZ, free tier):
# LLM_BASE_URL=https://ws-yreibc51vw8gp9za.ap-southeast-1.maas.aliyuncs.com/compatible-mode
# Local (LM Studio):
# LLM_BASE_URL=http://localhost:1234
# Local (Ollama):
# LLM_BASE_URL=http://localhost:11434

# Полный endpoint URL для backward compat (если ollama_service не используется)
LOCAL_AI_ENDPOINT=http://localhost:1234/v1/chat/completions

# Имя модели
# Cloud (Alibaba GLM): glm-5.2-fast-preview, glm-5.2, kimi-k2.7-code, ...
# Local (LM Studio): qwen_qwen2.5-vl-7b-instruct
# Local (Ollama): qwen2.5:3b
MODEL_NAME=qwen_qwen2.5-vl-7b-instruct

# === Логирование ===
# Уровень логирования: DEBUG / INFO / WARNING / ERROR
# Файл: logs/bot.log (rotation 10 MB × 5 файлов)
LOG_LEVEL=INFO

# === Режим уведомлений ===
# true  = авто-цикл отправляет в TG ТОЛЬКО при подтверждённом сигнале
#          (aggressive_breakout, retest, reversal).
# false = авто-цикл отправляет в TG каждый результат (как ручной /analyse).
AUTO_SIGNAL_ONLY=true

# === Облачная LLM для дашборда ===
# Отдельные ключи — основной бот остаётся на локальной LM Studio.
# Дашборд-бот использует эти ключи для /scan и других команд.
DASHBOARD_LLM_API_KEY=your_dashboard_api_key_here
DASHBOARD_LLM_BASE_URL=https://ws-yreibc51vw8gp9za.ap-southeast-1.maas.aliyuncs.com/compatible-mode
DASHBOARD_MODEL_NAME=glm-5.2-fast-preview
